{%- doc -%}
  Styles for the password layout: main content, password dialog, and email-signup
  used in the dialog. Rendered from layout/password.liquid (layouts cannot use the
  stylesheet tag directly).
{%- enddoc -%}

{% stylesheet %}
  body.page-width-{{ settings.page_width }} {
    min-height: 100vh;
    margin: 0;
    background:
      radial-gradient(circle at top right, rgba(132, 104, 196, 0.14), transparent 36%),
      linear-gradient(180deg, #fcf9fe 0%, #f6f0fb 100%);
    color: #172b4d;
    font-family: "Public Sans", sans-serif;
  }

  .password-main-content {
    flex: 1;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .password-dialog {
    max-width: 100vw;
    max-height: 100svh;
    width: 100vw;
    height: 100svh;
    border: none;
    background: rgba(18, 10, 31, 0.28);
    backdrop-filter: blur(12px);
    transition: opacity var(--animation-values), display var(--animation-speed) allow-discrete,
      overlay var(--animation-speed) allow-discrete;
  }

  .password-dialog::backdrop {
    display: none;
  }

  .password-dialog[open] {
    opacity: 1;
    top: 0;
    left: 0;
  }

  @starting-style {
    .password-dialog[open] {
      opacity: 0;
    }
  }

  .password-dialog:not([open]) {
    opacity: 0;
  }

  @starting-style {
    .password-dialog:not([open]) {
      opacity: 1;
    }
  }

  .password-dialog__close-button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.75rem;
    height: 2.75rem;
    border: 1px solid rgba(229, 225, 237, 0.82);
    border-radius: 4px;
    background: rgba(255, 255, 255, 0.92);
    color: #3d265a;
    cursor: pointer;
  }

  .password-dialog__header {
    position: absolute;
    top: 0;
    right: 0;
    padding: var(--padding-lg);
    z-index: var(--layer-raised);
  }

  .password-dialog__content {
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    padding: 1.5rem;
    height: 100%;
    transition: transform var(--animation-values);
  }

  .password-dialog__content .email-signup__message {
    width: 100%;
    max-width: 28rem;
    padding: 0.9rem 1rem 0;
    color: #de350b;
    font-size: 0.92rem;
    text-align: left;
  }

  .password-dialog[open] .password-dialog__content {
    transform: translateY(0);
  }

  @starting-style {
    .password-dialog[open] .password-dialog__content {
      transform: translateY(1em);
    }
  }

  .password-dialog:not([open]) .password-dialog__content {
    transform: translateY(1em);
  }

  @starting-style {
    .password-dialog:not([open]) .password-dialog__content {
      transform: translateY(0);
    }
  }

  .storefront-password-form {
    max-width: 28rem;
    width: 100%;
  }

  .section-password .section-background {
    display: none;
  }

  .section-password .section {
    width: min(100%, 72rem);
    margin: 0 auto;
    padding: clamp(2rem, 6vw, 4rem) 1.25rem;
  }

  .section-password .border-style {
    overflow: hidden;
    border: 1px solid #e5e1ed;
    border-radius: 4px;
    background:
      linear-gradient(120deg, rgba(61, 38, 90, 0.96) 0%, rgba(77, 52, 112, 0.92) 42%, rgba(132, 104, 196, 0.82) 100%);
    box-shadow: 0 20px 60px rgba(23, 43, 77, 0.08);
  }

  .section-password .section-content-wrapper {
    justify-content: center;
    align-items: flex-start;
    min-height: clamp(32rem, 74vh, 44rem);
    padding: clamp(2rem, 6vw, 4rem);
  }

  .section-password .shopify-section-group-header-group,
  .section-password .background-media,
  .section-password .background-image,
  .section-password .background-video {
    display: none;
  }

  .section-password .section-content-wrapper > * {
    width: min(100%, 32rem);
  }

  .section-password h1,
  .section-password h2,
  .section-password h3,
  .section-password .h1,
  .section-password .h2,
  .section-password .h3 {
    margin: 0;
    color: #ffffff;
    font-family: "Playfair Display", serif;
    font-weight: 500;
    letter-spacing: 0;
  }

  .section-password h1,
  .section-password .h1 {
    font-size: clamp(3rem, 6vw, 4.8rem);
    line-height: 0.95;
  }

  .section-password h2,
  .section-password h3,
  .section-password .h2,
  .section-password .h3 {
    font-size: clamp(2rem, 4vw, 3rem);
    line-height: 1.02;
  }

  .section-password p,
  .section-password .rte,
  .section-password .password-content {
    color: rgba(255, 255, 255, 0.82);
    font-size: 1.02rem;
    line-height: 1.8;
  }

  .section-password .password-content {
    margin-top: 1rem;
  }

  .section-password .newsletter-form,
  .section-password form[action*="contact"] {
    width: 100%;
  }

  .section-password .email-signup__input-group,
  .section-password .newsletter-form__input-group {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    gap: 0.75rem;
    width: 100%;
    margin-top: 1.5rem;
  }

  .section-password input[type="email"],
  .section-password input[type="password"],
  .section-password .field__input {
    width: 100%;
    min-height: 52px;
    padding: 0.95rem 1rem;
    border: 1px solid rgba(255, 255, 255, 0.26);
    border-radius: 4px;
    background: rgba(255, 255, 255, 0.12);
    color: #ffffff;
    box-shadow: none;
  }

  .section-password input::placeholder,
  .password-dialog input::placeholder {
    color: rgba(255, 255, 255, 0.62);
  }

  .section-password input:focus-visible,
  .password-dialog input:focus-visible {
    outline: 2px solid rgba(255, 255, 255, 0.42);
    outline-offset: 2px;
    border-color: rgba(255, 255, 255, 0.56);
  }

  .section-password button,
  .section-password .button,
  .password-dialog__submit-button {
    min-height: 52px;
    padding: 0.95rem 1.35rem;
    border: 1px solid transparent;
    border-radius: 4px;
    background: #ffffff;
    color: #3d265a;
    font-weight: 600;
    letter-spacing: 0.01em;
    box-shadow: none;
  }

  .section-password button:hover,
  .section-password .button:hover,
  .password-dialog__submit-button:hover {
    background: #f3edf9;
  }

  .password-dialog__title {
    color: #172b4d;
    font-family: "Playfair Display", serif;
    font-size: clamp(2.1rem, 4vw, 2.8rem);
    font-weight: 500;
  }

  .password-dialog__content {
    width: min(100%, 36rem);
    height: auto;
    margin: auto;
    border: 1px solid #e5e1ed;
    border-radius: 4px;
    background: rgba(255, 255, 255, 0.96);
    box-shadow: 0 18px 50px rgba(23, 43, 77, 0.12);
  }

  .password-dialog__content .field__input {
    background: #ffffff;
    color: #172b4d;
    border-color: #e5e1ed;
  }

  .password-dialog__content .field__input::placeholder {
    color: #8993a4;
  }

  .password-dialog__submit-button {
    width: 100%;
  }

  @media screen and (min-width: 750px) {
    .password-dialog__submit-button {
      width: auto;
    }
  }

  @media screen and (max-width: 749px) {
    .section-password .section-content-wrapper {
      min-height: auto;
      padding: 1.5rem;
    }

    .section-password .email-signup__input-group,
    .section-password .newsletter-form__input-group {
      grid-template-columns: 1fr;
    }

    .password-dialog__content {
      width: min(100%, 100%);
      padding: 1.25rem;
    }
  }
{% endstylesheet %}
