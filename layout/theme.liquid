<!doctype html>
<html lang="{{ request.locale.iso_code }}">
  <head>
    {% liquid
      assign is_quality_rescue = false
      assign catalog_url = routes.all_products_collection_url | default: '/collections/all'
      assign quality_canonical_url = shop.url | append: catalog_url | append: '?view=quality-safety'
      if request.path contains 'quality-safety' or request.params.view == 'quality-safety' or template.suffix == 'quality-safety'
        assign is_quality_rescue = true
      endif
    %}
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <title>
      {%- if is_quality_rescue -%}
        Quality & Safety | {{ shop.name }}
      {%- else -%}
        {{ page_title }}
        {%- if current_tags %} | {{ current_tags | join: ', ' }}{% endif -%}
        {%- if current_page != 1 %} | Page {{ current_page }}{% endif -%}
        {%- unless page_title contains shop.name %} | {{ shop.name }}{% endunless -%}
      {%- endif -%}
    </title>
    {%- if page_description -%}
      <meta name="description" content="{{ page_description | escape }}">
    {%- endif -%}
    {% if is_quality_rescue %}
      <link rel="canonical" href="{{ quality_canonical_url }}">
    {% else %}
      <link rel="canonical" href="{{ canonical_url }}">
    {% endif %}
    {%- if settings.favicon != blank -%}
      <link rel="icon" href="{{ settings.favicon | image_url: width: 32, height: 32 }}" type="image/png">
    {%- endif -%}
    {% # theme-check-disable RemoteAsset %}
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link
      href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@500;600;700&family=Public+Sans:wght@300;400;500;600;700&display=swap"
      rel="stylesheet"
    >
    {% # theme-check-enable RemoteAsset %}
    {{ 'ell.css' | asset_url | stylesheet_tag }}
    <script src="{{ 'ell.js' | asset_url }}" defer></script>
    {{ content_for_header }}
  </head>
  {% liquid
    assign provider_registration_url = catalog_url | append: '?view=provider-registration'
    assign provider_approved = false
    assign provider_pending = false
    if customer
      if customer.tags contains 'provider-approved'
        assign provider_approved = true
      endif
      if customer.tags contains 'provider-pending'
        assign provider_pending = true
      endif
    endif
  %}
  <body
    class="ell-page ell-page--{{ template.name | handle }}{% if template.suffix != blank %} ell-page--{{ template.suffix | handle }}{% endif %}{% if is_quality_rescue %} ell-page--quality-safety{% endif %}"
    data-catalog-url="{{ catalog_url }}"
    data-provider-registration-url="{{ provider_registration_url }}"
    data-provider-registration-endpoint="{{ settings.provider_registration_endpoint | escape }}"
    data-customer-logged-in="{% if customer %}true{% else %}false{% endif %}"
    data-provider-approved="{{ provider_approved }}"
    data-provider-pending="{{ provider_pending }}"
  >
    {% section 'header' %}
    <main id="MainContent" role="main">
      {{ content_for_layout }}
    </main>
    {% section 'footer' %}
  </body>
</html>
