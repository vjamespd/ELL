{% liquid
  assign render_quality_page = true
  if template.name == '404' and request.path contains 'quality-safety'
    assign render_quality_page = true
  elsif template.name == '404'
    assign render_quality_page = false
  endif
%}

{% if render_quality_page %}
<section class="ell-section quality-page">
  <div class="ell-container quality-layout">
    <aside class="quality-sidebar">
      <p class="quality-sidebar__eyebrow">On This Page</p>
      <nav class="quality-sidebar__nav">
        <a class="is-active" href="#quality-compliance">Documentation Review</a>
        <a href="#quality-process">Review Workflow</a>
        <a href="#quality-literature">Resource Library</a>
      </nav>
    </aside>

    <div class="quality-main">
      <section class="quality-page__hero">
        <h1 class="quality-title">{{ section.settings.heading }}</h1>
        <p class="quality-lead">{{ section.settings.body }}</p>
      </section>

      <section class="quality-content-section" id="quality-compliance">
        <h2 class="quality-section-title">{{ section.settings.compliance_heading }}</h2>
        <p class="quality-copy">{{ section.settings.compliance_body }}</p>
        <div class="quality-certs">
          {% assign cert_blocks = section.blocks | where: 'type', 'certification' %}
          {% if cert_blocks.size > 0 %}
            {% for block in cert_blocks %}
              <article class="cert-card" {{ block.shopify_attributes }}>
                <div class="quality-cert__icon">{% render 'icon', name: block.settings.icon %}</div>
                <h3>{{ block.settings.title }}</h3>
                <p>{{ block.settings.body }}</p>
              </article>
            {% endfor %}
          {% else %}
            <article class="cert-card">
              <div class="quality-cert__icon">{% render 'icon', name: 'verified' %}</div>
              <h3>Documentation Ready</h3>
              <p>Product documentation can be prepared for provider and institutional quality review.</p>
            </article>
            <article class="cert-card">
              <div class="quality-cert__icon">{% render 'icon', name: 'shield' %}</div>
              <h3>Provider Due Diligence</h3>
              <p>Ordering workflows are structured to support provider-led review before fulfillment.</p>
            </article>
            <article class="cert-card">
              <div class="quality-cert__icon">{% render 'icon', name: 'flask' %}</div>
              <h3>Handling Review</h3>
              <p>Shipping and handling protocols are reviewed according to product specifications.</p>
            </article>
          {% endif %}
        </div>
      </section>

      <section class="quality-content-section" id="quality-process">
        <h2 class="quality-section-title">{{ section.settings.timeline_heading }}</h2>
        <div class="timeline-list">
          {% assign timeline_blocks = section.blocks | where: 'type', 'timeline' %}
          {% if timeline_blocks.size > 0 %}
            {% for block in timeline_blocks %}
              <article class="timeline-item" {{ block.shopify_attributes }}>
                <h3>{{ block.settings.title }}</h3>
                <p>{{ block.settings.body }}</p>
              </article>
            {% endfor %}
          {% else %}
            <article class="timeline-item"><h3>1. Product Intake</h3><p>Product interest and institutional requirements are collected before documentation or ordering review begins.</p></article>
            <article class="timeline-item"><h3>2. Documentation Review</h3><p>Manufacturing documentation, lot details, and handling information may be made available upon provider or institutional request.</p></article>
            <article class="timeline-item"><h3>3. Ordering Review</h3><p>Orders may be reviewed for provider, institutional, and shipping eligibility before fulfillment.</p></article>
            <article class="timeline-item"><h3>4. Shipping Coordination</h3><p>Shipping and handling protocols are subject to product specifications and destination requirements.</p></article>
          {% endif %}
        </div>
      </section>

      <section class="quality-content-section" id="quality-literature">
        <h2 class="quality-section-title">{{ section.settings.literature_heading }}</h2>
        <p class="quality-copy">{{ section.settings.literature_body }}</p>
        <div class="resource-list">
          {% assign resource_blocks = section.blocks | where: 'type', 'resource' %}
          {% if resource_blocks.size > 0 %}
            {% for block in resource_blocks %}
              {% assign resource_url = block.settings.link | default: '/search?q=quality' %}
              <a class="resource-card" href="{{ resource_url }}" {{ block.shopify_attributes }}>
                <span class="resource-card__icon">{% render 'icon', name: 'file' %}</span>
                <div>
                  <strong>{{ block.settings.title }}</strong>
                  <p>{{ block.settings.body }}</p>
                </div>
                <span class="resource-card__type">{{ block.settings.file_type }}</span>
                <span class="resource-card__size">{{ block.settings.file_size }}</span>
                <span class="resource-card__download">{% render 'icon', name: 'download' %}</span>
              </a>
            {% endfor %}
          {% else %}
            <a class="resource-card" href="/search?q=documentation"><span class="resource-card__icon">{% render 'icon', name: 'file' %}</span><div><strong>Product Documentation Request</strong><p>Documentation availability can be reviewed for provider and institutional due diligence.</p></div><span class="resource-card__type">Request</span><span class="resource-card__size">Review</span><span class="resource-card__download">{% render 'icon', name: 'download' %}</span></a>
            <a class="resource-card" href="/search?q=handling"><span class="resource-card__icon">{% render 'icon', name: 'file' %}</span><div><strong>Shipping &amp; Handling Considerations</strong><p>Handling protocols are subject to product specifications and destination requirements.</p></div><span class="resource-card__type">Info</span><span class="resource-card__size">Review</span><span class="resource-card__download">{% render 'icon', name: 'download' %}</span></a>
            <a class="resource-card" href="/search?q=quality"><span class="resource-card__icon">{% render 'icon', name: 'file' %}</span><div><strong>Quality Review Materials</strong><p>Quality-focused biologic solutions are organized for documentation review before institutional ordering.</p></div><span class="resource-card__type">Info</span><span class="resource-card__size">Review</span><span class="resource-card__download">{% render 'icon', name: 'download' %}</span></a>
          {% endif %}
        </div>
      </section>
    </div>
  </div>
</section>
{% endif %}

{% schema %}
{
  "name": "ELL quality & safety",
  "max_blocks": 12,
  "blocks": [
    {
      "type": "certification",
      "name": "Certification",
      "settings": [
        { "type": "text", "id": "title", "label": "Title", "default": "Documentation Ready" },
        { "type": "textarea", "id": "body", "label": "Body", "default": "Product documentation can be prepared for provider and institutional quality review." },
        {
          "type": "select",
          "id": "icon",
          "label": "Icon",
          "default": "verified",
          "options": [
            { "value": "verified", "label": "Verified" },
            { "value": "shield", "label": "Shield" },
            { "value": "flask", "label": "Flask" }
          ]
        }
      ]
    },
    {
      "type": "timeline",
      "name": "Timeline step",
      "settings": [
        { "type": "text", "id": "title", "label": "Title", "default": "1. Product Intake" },
        { "type": "textarea", "id": "body", "label": "Body", "default": "Product interest and institutional requirements are collected before documentation or ordering review begins." }
      ]
    },
    {
      "type": "resource",
      "name": "Resource",
      "settings": [
        { "type": "text", "id": "title", "label": "Title", "default": "Product Documentation Request" },
        { "type": "textarea", "id": "body", "label": "Body", "default": "Documentation availability can be reviewed for provider and institutional due diligence." },
        { "type": "text", "id": "file_type", "label": "File type", "default": "Request" },
        { "type": "text", "id": "file_size", "label": "File size", "default": "Review" },
        { "type": "url", "id": "link", "label": "Link" }
      ]
    }
  ],
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Quality & Safety" },
    { "type": "textarea", "id": "body", "label": "Body", "default": "A documentation-ready quality review experience for provider-led regenerative medicine workflows, institutional ordering, and shipping eligibility review." },
    { "type": "text", "id": "compliance_heading", "label": "Compliance heading", "default": "Documentation Review" },
    { "type": "textarea", "id": "compliance_body", "label": "Compliance body", "default": "Product, manufacturing, and handling documentation may be reviewed with providers and institutional buyers before fulfillment. Specific certifications or registrations should be confirmed against current documentation." },
    { "type": "text", "id": "timeline_heading", "label": "Timeline heading", "default": "Review Workflow" },
    { "type": "text", "id": "literature_heading", "label": "Literature heading", "default": "Resource Library" },
    { "type": "textarea", "id": "literature_body", "label": "Literature body", "default": "Request quality review materials, product documentation, and shipping or handling details for provider and institutional due diligence." }
  ]
}
{% endschema %}
