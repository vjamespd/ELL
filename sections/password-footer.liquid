

<div
  class="password-footer color-{{ section.settings.color_scheme }}"
  data-testid="password-footer"
>
  <p class="password-footer__powered-by">
    {{ 'content.powered_by' | t }}
    <a
      href="//shopify.com"
      rel="nofollow"
      target="_blank"
      aria-label="Shopify"
      aria-describedby="a11y-new-window-message"
    >
      {{- 'icon-shopify.svg' | inline_asset_content -}}
    </a>
  </p>
  <div class="password-footer__links">
    <button
      class="button-unstyled password-footer__button"
      on:click="#password-form/showDialog"
    >
      {{ 'actions.enter_using_password' | t }}
    </button>
    <p class="password-footer__admin-link">
      {{ 'content.store_owner_link_html' | t: link: '/admin' }}
    </p>
  </div>
  <ul hidden>
    <li id="a11y-new-window-message">{{ 'accessibility.new_window' | t }}</li>
  </ul>
</div>

{% stylesheet %}
  .password-footer {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.8rem;
    padding: 1.2rem 1.5rem 2rem;
    color: #5e6a7f;
  }

  .password-footer__powered-by {
    margin: 0;
    display: flex;
    align-items: center;
    gap: 0.35rem;
    height: auto;
    font-size: 0.9rem;
  }

  .password-footer__powered-by > a {
    display: flex;
  }

  .password-footer__powered-by .icon-shopify {
    display: inline;
    height: 1.2em;
    color: #3d265a;
  }

  .password-footer__links {
    display: flex;
    align-items: center;
    gap: 1.1rem;
    flex-wrap: wrap;
    justify-content: center;
  }

  .password-footer__admin-link {
    margin: 0;
  }

  .password-footer__admin-link a {
    color: #3d265a;
    font-weight: 600;
  }

  .password-footer__button {
    min-height: 44px;
    padding: 0.65rem 0.9rem;
    border: 1px solid #e5e1ed;
    border-radius: 4px;
    background-color: #ffffff;
    color: #3d265a;
    font-weight: 600;
    cursor: pointer;
    text-decoration: none;
  }

  .password-footer__button:hover {
    background: #f7f2fb;
  }

  @media screen and (max-width: 749px) {
    .password-footer__links {
      flex-direction: column;
      gap: 0.7rem;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:names.footer_password",
  "class": "section-wrapper",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:settings.color_scheme",
      "default": "scheme-1"
    }
  ]
}
{% endschema %}
