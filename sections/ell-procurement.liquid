{% liquid
  assign summary_title = section.settings.summary_title
  assign summary_lot = section.settings.summary_lot
  assign summary_cells = section.settings.summary_cells
  assign summary_viability = section.settings.summary_viability
  assign summary_total = section.settings.summary_total

  if cart.item_count > 0
    assign summary_title = cart.items.first.product.title
    assign summary_lot = cart.items.first.variant.sku | default: cart.items.first.product.handle | upcase
    assign summary_cells = 'Clinical allocation'
    assign summary_viability = 'Pending lot review'
    assign summary_total = cart.total_price | money
  endif
%}

<section class="ell-section procurement-page__hero">
  <div class="ell-container">
    <div class="procurement-layout">
      <div>
        <h1 class="section-title">{{ section.settings.heading }}</h1>
        <p class="lead-copy">{{ section.settings.body }}</p>
      </div>

      <nav class="procurement-steps" aria-label="Procurement steps">
        <div class="procurement-step is-active">01 Verification</div>
        <div class="procurement-step">02 Shipping</div>
        <div class="procurement-step">03 Payment</div>
      </nav>

      <div class="procurement-card">
        <div class="procurement-summary">
          <div class="procurement-line">
            <strong>{{ summary_title }}</strong>
            <strong>{{ summary_cells }}</strong>
          </div>
          <div class="procurement-line">
            <span class="muted-copy">Lot: {{ summary_lot }}</span>
            <span class="status-chip status-chip--verified">{{ summary_viability }}</span>
          </div>
          <div class="procurement-line" style="padding-top:1rem;border-top:1px solid rgba(39,15,68,0.08);">
            <span class="muted-copy">Estimated Subtotal</span>
            <strong>{{ summary_total }}</strong>
          </div>
        </div>

        {% form 'contact', class: 'procurement-inquiry-form' %}
          {% if form.posted_successfully? %}
            <div class="form-status form-status--success">{{ section.settings.success_message }}</div>
          {% endif %}

          {% if form.errors %}
            <div class="form-status form-status--error">
              {{ form.errors | default_errors }}
            </div>
          {% endif %}

          <input type="hidden" name="contact[subject]" value="Cart inquiry">
          <input type="hidden" name="contact[cart_summary]" value="{{ summary_title }} / {{ summary_total }}">

          <div class="procurement-form-section">
            <h2 class="panel-title">{{ section.settings.provider_heading }}</h2>
            <p class="muted-copy">{{ section.settings.provider_body }}</p>
            <div class="procurement-form-grid">
              <div>
                <label class="stat-label" for="ProcurementName">Name</label>
                <input id="ProcurementName" class="field" type="text" name="contact[name]" autocomplete="name" required>
              </div>
              <div>
                <label class="stat-label" for="ProcurementEmail">Email</label>
                <input id="ProcurementEmail" class="field" type="email" name="contact[email]" autocomplete="email" required>
              </div>
              <div>
                <label class="stat-label" for="ProcurementNpi">National Provider Identifier (NPI)</label>
                <input id="ProcurementNpi" class="field" type="text" name="contact[npi]" placeholder="10-digit NPI, if applicable" inputmode="numeric">
              </div>
              <div>
                <label class="stat-label" for="ProcurementInstitution">Institution or clinic</label>
                <input id="ProcurementInstitution" class="field" type="text" name="contact[institution]" placeholder="Institution, clinic, or organization">
              </div>
            </div>
          </div>

          <div class="procurement-form-section">
            <h2 class="panel-title">{{ section.settings.interest_heading }}</h2>
            <div class="procurement-form-grid">
              <div>
                <label class="stat-label" for="ProcurementProductInterest">Product interest</label>
                <input id="ProcurementProductInterest" class="field" type="text" name="contact[product_interest]" value="{{ summary_title }}">
              </div>
              <div>
                <label class="stat-label" for="ProcurementDocumentation">Documentation requests</label>
                <input id="ProcurementDocumentation" class="field" type="text" name="contact[documentation_requests]" placeholder="COA, handling specs, institutional paperwork">
              </div>
            </div>
            <label class="stat-label" for="ProcurementMessage">Shipping, handling, or ordering considerations</label>
            <textarea id="ProcurementMessage" class="field-textarea" name="contact[body]" rows="5" placeholder="Share destination, timing, documentation, or product review needs."></textarea>
          </div>

          <div class="procurement-note" style="margin:1.25rem 0;">
            {% render 'icon', name: 'lock' %}
            <div class="muted-copy" style="font-size:0.86rem;">{{ section.settings.note }}</div>
          </div>

          <button class="ell-button ell-button--primary" type="submit" style="width:100%;">
            {{ section.settings.button_label }}
            {% render 'icon', name: 'arrow-right' %}
          </button>
        {% endform %}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "ELL procurement",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Institutional cart inquiry" },
    { "type": "textarea", "id": "body", "label": "Body", "default": "Submit provider, institution, product interest, documentation, and shipping considerations for review before ordering or fulfillment." },
    { "type": "text", "id": "summary_title", "label": "Summary title", "default": "Product interest pending" },
    { "type": "text", "id": "summary_lot", "label": "Summary lot", "default": "To be assigned" },
    { "type": "text", "id": "summary_cells", "label": "Summary cells", "default": "Documentation review" },
    { "type": "text", "id": "summary_viability", "label": "Summary viability", "default": "Pending review" },
    { "type": "text", "id": "summary_total", "label": "Summary total", "default": "Pending review" },
    { "type": "text", "id": "provider_heading", "label": "Provider heading", "default": "Provider and institution information" },
    { "type": "textarea", "id": "provider_body", "label": "Provider body", "default": "Use this form for provider-led regenerative medicine workflows and institutional documentation requests." },
    { "type": "text", "id": "interest_heading", "label": "Interest heading", "default": "Product interest and documentation requests" },
    { "type": "text", "id": "success_message", "label": "Success message", "default": "Cart inquiry received. The team will review your request and follow up." },
    { "type": "textarea", "id": "note", "label": "Review note", "default": "Orders may be reviewed for provider, institutional, and shipping eligibility before fulfillment. This form does not perform real-time provider verification." },
    { "type": "text", "id": "button_label", "label": "Button label", "default": "Submit Inquiry" }
  ]
}
{% endschema %}
