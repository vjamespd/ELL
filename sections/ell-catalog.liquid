{% liquid
  assign procurement_url = section.settings.procurement_link | default: routes.cart_url | default: '/cart'
  assign coa_url = section.settings.coa_link
%}

<section class="ell-section catalog-dossier-page catalog-page__hero">
  <div class="ell-container detail-layout">
    <div class="detail-main">
      <div>
        <div class="detail-kicker catalog-lot-kicker">
          <span class="catalog-lot-tag">{{ section.settings.status_label }}</span>
          <span class="eyebrow" style="margin:0;">ID: {{ section.settings.lot_id }}</span>
        </div>
        <h1 class="display-title catalog-dossier__title">{{ section.settings.heading }}</h1>
        <p class="lead-copy detail-summary">{{ section.settings.body }}</p>
      </div>

      <article class="coa-card catalog-coa-card">
        <div class="coa-card__head">
          <div>
            <h2 class="serif-title" style="margin:0;font-size:2.1rem;">{{ section.settings.coa_heading }}</h2>
            <p class="muted-copy" style="margin:0.35rem 0 0;">{{ section.settings.coa_reference }}</p>
          </div>
          {% if coa_url != blank %}
            <a class="ell-button ell-button--text" href="{{ coa_url }}">
              {% render 'icon', name: 'download' %}
              {{ section.settings.coa_button }}
            </a>
          {% endif %}
        </div>

        <div class="detail-stats">
          {% assign metric_blocks = section.blocks | where: 'type', 'metric' %}
          {% if metric_blocks.size > 0 %}
            {% for block in metric_blocks %}
              <div class="metric-card" {{ block.shopify_attributes }}>
                <span class="stat-label">{{ block.settings.label }}</span>
                <div class="metric-card__value">{{ block.settings.value }}</div>
              </div>
            {% endfor %}
          {% else %}
            <div class="metric-card"><span class="stat-label">Documentation</span><div class="metric-card__value">Available</div></div>
            <div class="metric-card"><span class="stat-label">Lot Review</span><div class="metric-card__value">On Request</div></div>
            <div class="metric-card"><span class="stat-label">Handling</span><div class="metric-card__value">Product Specific</div></div>
            <div class="metric-card"><span class="stat-label">Ordering</span><div class="metric-card__value">Reviewed</div></div>
          {% endif %}
        </div>

        <div class="coa-visual catalog-coa-visual">
          {% if section.settings.visual_image != blank %}
            {{
              section.settings.visual_image
              | image_url: width: 1200
              | image_tag:
                alt: section.settings.heading,
                widths: '600,900,1200',
                class: 'coa-visual__image',
                style: 'width:100%;height:100%;object-fit:cover;filter:grayscale(100%);opacity:0.55;mix-blend-mode:multiply;'
            }}
          {% endif %}
          <span class="chip coa-visual__badge catalog-coa-visual__badge">
            {% render 'icon', name: 'download' %}
            {{ section.settings.scan_badge }}
          </span>
        </div>
      </article>

      <div>
        <h2 class="serif-title" style="margin:0 0 1.5rem;font-size:2rem;">{{ section.settings.spec_heading }}</h2>
        <div class="spec-grid">
          {% assign spec_blocks = section.blocks | where: 'type', 'spec' %}
          {% if spec_blocks.size > 0 %}
            {% for block in spec_blocks %}
              <div class="spec-item" {{ block.shopify_attributes }}>
                <span class="stat-label">{{ block.settings.label }}</span>
                <strong>{{ block.settings.value }}</strong>
              </div>
            {% endfor %}
          {% else %}
            <div class="spec-item"><span class="stat-label">Product Type</span><strong>Biologic solution</strong></div>
            <div class="spec-item"><span class="stat-label">Documentation</span><strong>Available upon review</strong></div>
            <div class="spec-item"><span class="stat-label">Format</span><strong>Product specific</strong></div>
            <div class="spec-item"><span class="stat-label">Storage</span><strong>Subject to specifications</strong></div>
          {% endif %}
        </div>
      </div>
    </div>

    <aside class="detail-panel catalog-alloc-panel" data-inquiry-root>
      <div class="catalog-alloc-panel__head">
        <div>
          <p class="eyebrow" style="margin-bottom:0.5rem;">{{ section.settings.panel_eyebrow }}</p>
          <h2 class="serif-title" style="margin:0;font-size:2.6rem;">{{ section.settings.panel_heading }}</h2>
        </div>
        <span class="catalog-reserve">
          <span class="catalog-reserve__dot"></span>
          {{ section.settings.panel_status }}
        </span>
      </div>

      <div class="detail-panel__summary">
        <div class="detail-panel__line"><span class="muted-copy">Lead Time</span><strong>{{ section.settings.lead_time }}</strong></div>
        <div class="detail-panel__line"><span class="muted-copy">Shipping Condition</span><strong>{{ section.settings.shipping_condition }}</strong></div>
        <div class="detail-panel__line"><span class="muted-copy">Min. Order</span><strong>{{ section.settings.minimum_order }}</strong></div>
      </div>

      <a class="ell-button ell-button--primary catalog-alloc-button" href="{{ procurement_url }}">
        {{ section.settings.panel_button }}
        {% render 'icon', name: 'arrow-right' %}
      </a>

      <div class="verification-box" data-verification-root>
        <div style="display:flex;gap:0.75rem;align-items:flex-start;">
          <span class="catalog-verify-icon">{% render 'icon', name: 'verified' %}</span>
          <div>
            <strong>{{ section.settings.verify_heading }}</strong>
            <p class="muted-copy" style="margin:0.35rem 0 0.75rem;font-size:0.86rem;">{{ section.settings.verify_body }}</p>
          </div>
        </div>
        <div class="catalog-verify-row">
          <label class="visually-hidden" for="catalog-npi-{{ section.id }}">National Provider Identifier</label>
          <input id="catalog-npi-{{ section.id }}" class="field" type="text" placeholder="Enter NPI Number" inputmode="numeric" data-npi-input>
          <button class="ell-button ell-button--ghost" type="button" data-verify-trigger>{{ section.settings.verify_button }}</button>
        </div>
        <div class="verification-status" data-verification-status></div>
      </div>

      <div class="catalog-compliance">
        <p class="stat-label" style="margin-bottom:0.75rem;text-align:center;">{{ section.settings.badges_heading }}</p>
        <div class="catalog-compliance__badges">
          {% assign badge_blocks = section.blocks | where: 'type', 'badge' %}
          {% if badge_blocks.size > 0 %}
            {% for block in badge_blocks %}
              <span class="catalog-outline-badge" {{ block.shopify_attributes }}>{{ block.settings.label }}</span>
            {% endfor %}
          {% else %}
            <span class="catalog-outline-badge">Documentation</span>
            <span class="catalog-outline-badge">Quality Review</span>
            <span class="catalog-outline-badge">Handling Specs</span>
          {% endif %}
        </div>
      </div>

      <div class="support-card catalog-support-card surface-card">
        <span class="support-card__icon catalog-support-card__icon">{% render 'icon', name: 'support' %}</span>
        <div>
          <strong>{{ section.settings.support_heading }}</strong>
          <p class="muted-copy" style="margin:0.25rem 0 0;font-size:0.86rem;">{{ section.settings.support_body }}</p>
        </div>
      </div>
    </aside>
  </div>
</section>

{% schema %}
{
  "name": "ELL catalog",
  "max_blocks": 12,
  "blocks": [
    {
      "type": "metric",
      "name": "Metric",
      "settings": [
        { "type": "text", "id": "label", "label": "Label", "default": "Documentation" },
        { "type": "text", "id": "value", "label": "Value", "default": "Available on request" }
      ]
    },
    {
      "type": "spec",
      "name": "Specification",
      "settings": [
        { "type": "text", "id": "label", "label": "Label", "default": "Product Type" },
        { "type": "text", "id": "value", "label": "Value", "default": "Biologic solution" }
      ]
    },
    {
      "type": "badge",
      "name": "Review badge",
      "settings": [
        { "type": "text", "id": "label", "label": "Label", "default": "Documentation" }
      ]
    }
  ],
  "settings": [
    { "type": "text", "id": "status_label", "label": "Status label", "default": "Review Ready" },
    { "type": "text", "id": "lot_id", "label": "Lot ID", "default": "Pending lot review" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Quality-focused biologic solution" },
    { "type": "textarea", "id": "body", "label": "Body", "default": "Product information, documentation, handling details, and ordering considerations are organized for provider and institutional review." },
    { "type": "text", "id": "coa_heading", "label": "COA heading", "default": "Documentation Review" },
    { "type": "text", "id": "coa_reference", "label": "COA reference", "default": "Available upon provider or institutional review." },
    { "type": "text", "id": "coa_button", "label": "COA button label", "default": "Review PDF" },
    { "type": "url", "id": "coa_link", "label": "COA link" },
    { "type": "image_picker", "id": "visual_image", "label": "Culture scan image" },
    { "type": "text", "id": "scan_badge", "label": "Scan badge", "default": "Documentation Preview" },
    { "type": "text", "id": "spec_heading", "label": "Specifications heading", "default": "Review Details" },
    { "type": "text", "id": "panel_eyebrow", "label": "Panel eyebrow", "default": "Cart" },
    { "type": "text", "id": "panel_heading", "label": "Panel heading", "default": "Begin Review" },
    { "type": "text", "id": "panel_status", "label": "Panel status", "default": "Order Review" },
    { "type": "text", "id": "lead_time", "label": "Lead time", "default": "Reviewed after inquiry" },
    { "type": "text", "id": "shipping_condition", "label": "Shipping condition", "default": "Subject to product specifications" },
    { "type": "text", "id": "minimum_order", "label": "Minimum order", "default": "Product specific" },
    { "type": "text", "id": "panel_button", "label": "Panel button label", "default": "Open Cart" },
    { "type": "text", "id": "verify_heading", "label": "Verification heading", "default": "Provider details requested" },
    { "type": "textarea", "id": "verify_body", "label": "Verification body", "default": "Provider and institutional details may be reviewed before pricing, documentation, or fulfillment steps are completed." },
    { "type": "text", "id": "verify_button", "label": "Verification button", "default": "Prepare Review" },
    { "type": "text", "id": "badges_heading", "label": "Compliance heading", "default": "Review Materials" },
    { "type": "text", "id": "support_heading", "label": "Support heading", "default": "Provider support" },
    { "type": "text", "id": "support_body", "label": "Support body", "default": "Product, documentation, and ordering questions can be routed for review." },
    { "type": "url", "id": "procurement_link", "label": "Procurement page link" }
  ]
}
{% endschema %}
