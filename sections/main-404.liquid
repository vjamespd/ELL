{% liquid
  assign catalog_url = routes.all_products_collection_url | default: '/collections/all'
  assign cart_url = routes.cart_url | default: '/cart'
  assign quality_url = catalog_url | append: '?view=quality-safety'
  assign is_quality_rescue = false
  assign is_featured_biologic_coming_soon = false
  assign error_eyebrow = section.settings.eyebrow
  assign error_heading = section.settings.heading
  assign error_body = section.settings.body
  assign primary_label = section.settings.primary_label
  assign secondary_label = section.settings.secondary_label
  if request.path contains 'quality-safety'
    assign is_quality_rescue = true
  endif

  if request.path contains 'featured-biologic-of-the-month'
    assign is_featured_biologic_coming_soon = true
    assign error_eyebrow = 'Featured Biologic'
    assign error_heading = 'Coming Soon'
    assign error_body = 'Product details for the Featured Biologic of the Month will be published here once the spotlight release is finalized.'
    assign primary_label = 'Return Home'
    assign secondary_label = 'Provider Registration'
  endif
%}

<script>
  {
    const path = window.location.pathname.replace(/\/$/, '');
    const redirects = {
      '/pages/quality-safety': '{{ quality_url }}',
      '/pages/legal-compliance': '{{ quality_url }}',
      '/policies/terms-of-service': '/policies/privacy-policy'
    };

    if (redirects[path]) {
      window.location.replace(redirects[path]);
    }
  }
</script>

{% if is_featured_biologic_coming_soon %}
  <section class="ell-section ell-error-page">
    <div class="ell-container">
      <div class="error-shell surface-card">
        <p class="eyebrow">{{ error_eyebrow }}</p>
        <h1 class="display-title">{{ error_heading }}</h1>
        <p class="lead-copy">{{ error_body }}</p>

        <div class="button-row" style="margin-top: 2rem;">
          <a class="ell-button ell-button--primary" href="{{ routes.root_url }}">
            {{ primary_label }}
            {% render 'icon', name: 'arrow-right' %}
          </a>
          <a class="ell-button ell-button--ghost" href="{{ routes.all_products_collection_url | default: '/collections/all' }}?view=provider-registration">
            {{ secondary_label }}
          </a>
        </div>
      </div>
    </div>
  </section>
{% elsif is_quality_rescue == false %}
  <section class="ell-section ell-error-page" data-generic-404>
    <div class="ell-container">
      <div class="error-shell surface-card">
        <p class="eyebrow">{{ error_eyebrow }}</p>
        <h1 class="display-title">{{ error_heading }}</h1>
        <p class="lead-copy">{{ error_body }}</p>

        <div class="button-row" style="margin-top: 2rem;">
          <a class="ell-button ell-button--primary" href="{{ routes.root_url }}">
            {{ primary_label }}
            {% render 'icon', name: 'arrow-right' %}
          </a>
          <a class="ell-button ell-button--ghost" href="{{ catalog_url }}">
            {{ secondary_label }}
          </a>
        </div>

        <div class="error-links">
          <a href="{{ quality_url }}">{{ section.settings.quality_label }}</a>
          <a href="{{ cart_url }}">{{ section.settings.procurement_label }}</a>
          <a href="{{ routes.account_login_url | default: '/account/login' }}">{{ section.settings.login_label }}</a>
        </div>
      </div>
    </div>
  </section>
{% endif %}

{% schema %}
{
  "name": "Main 404",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Clinical Navigation"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Page unavailable."
    },
    {
      "type": "textarea",
      "id": "body",
      "label": "Body",
      "default": "The resource you requested is not available at this route. Return to the ell. homepage or continue into the clinical inventory experience."
    },
    {
      "type": "text",
      "id": "primary_label",
      "label": "Primary button label",
      "default": "Return Home"
    },
    {
      "type": "text",
      "id": "secondary_label",
      "label": "Secondary button label",
      "default": "Browse Inventory"
    },
    {
      "type": "text",
      "id": "quality_label",
      "label": "Quality link label",
      "default": "Quality & Safety"
    },
    {
      "type": "text",
      "id": "procurement_label",
      "label": "Cart link label",
      "default": "Cart"
    },
    {
      "type": "text",
      "id": "login_label",
      "label": "Login link label",
      "default": "Provider Log In"
    }
  ]
}
{% endschema %}
