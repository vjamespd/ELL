<section class="ell-section ell-error-page">
  <div class="ell-container">
    <div class="error-shell surface-card">
      <p class="eyebrow">{{ section.settings.eyebrow }}</p>
      <h1 class="display-title">{{ section.settings.heading }}</h1>
      <p class="lead-copy">{{ section.settings.body }}</p>

      <div class="button-row" style="margin-top: 2rem;">
        <a class="ell-button ell-button--primary" href="{{ routes.root_url }}">
          {{ section.settings.primary_label }}
          {% render 'icon', name: 'arrow-right' %}
        </a>
        <a class="ell-button ell-button--ghost" href="/pages/catalog">
          {{ section.settings.secondary_label }}
        </a>
      </div>

      <div class="error-links">
        <a href="/pages/quality-safety">{{ section.settings.quality_label }}</a>
        <a href="/pages/procurement">{{ section.settings.procurement_label }}</a>
        <a href="{{ routes.account_login_url | default: '/account/login' }}">{{ section.settings.login_label }}</a>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Main 404",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Clinical Navigation"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Page unavailable."
    },
    {
      "type": "textarea",
      "id": "body",
      "label": "Body",
      "default": "The resource you requested is not available at this route. Return to the ell. homepage or continue into the clinical inventory experience."
    },
    {
      "type": "text",
      "id": "primary_label",
      "label": "Primary button label",
      "default": "Return Home"
    },
    {
      "type": "text",
      "id": "secondary_label",
      "label": "Secondary button label",
      "default": "Browse Inventory"
    },
    {
      "type": "text",
      "id": "quality_label",
      "label": "Quality link label",
      "default": "Quality & Safety"
    },
    {
      "type": "text",
      "id": "procurement_label",
      "label": "Procurement link label",
      "default": "Procurement"
    },
    {
      "type": "text",
      "id": "login_label",
      "label": "Login link label",
      "default": "Provider Log In"
    }
  ]
}
{% endschema %}
