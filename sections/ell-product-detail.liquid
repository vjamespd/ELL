{% liquid
  assign current_product = product
  assign current_variant = current_product.selected_or_first_available_variant
  assign product_title = current_product.title | default: section.settings.fallback_title
  assign product_body = current_product.description | strip_html
  if product_body == blank
    assign product_body = section.settings.fallback_body
  endif

  assign metafield_lot_id = current_product.metafields.custom.lot_id.value
  assign lot_id = current_variant.sku | default: metafield_lot_id | default: section.settings.lot_id
  assign lead_time = current_product.metafields.custom.lead_time.value | default: section.settings.lead_time
  assign shipping_condition = current_product.metafields.custom.shipping_condition.value | default: section.settings.shipping_condition
  assign minimum_order = current_product.metafields.custom.minimum_order.value | default: section.settings.minimum_order
  assign coa_reference = current_product.metafields.custom.coa_reference.value | default: section.settings.coa_reference
  assign coa_url = current_product.metafields.custom.coa_pdf.value | default: section.settings.coa_link
  assign viability = current_product.metafields.custom.viability.value | default: section.settings.fallback_viability
  assign passage = current_product.metafields.custom.passage.value | default: section.settings.fallback_passage
  assign sterility = current_product.metafields.custom.sterility.value | default: section.settings.fallback_sterility
  assign endotoxin = current_product.metafields.custom.endotoxin.value | default: section.settings.fallback_endotoxin
  assign cell_type = current_product.metafields.custom.cell_type.value | default: current_product.type | default: section.settings.fallback_cell_type
  assign characterization = current_product.metafields.custom.characterization.value | default: section.settings.fallback_characterization
  assign product_format = current_product.metafields.custom.format.value | default: current_variant.title | default: section.settings.fallback_format
  assign storage = current_product.metafields.custom.storage.value | default: section.settings.fallback_storage
  assign cart_url = routes.cart_url | default: '/cart'
  assign catalog_url = routes.all_products_collection_url | default: '/collections/all'
  assign provider_registration_url = catalog_url | append: '?view=provider-registration'
  assign selected_quantity = current_variant.quantity_rule.min | default: 1
  assign provider_approved = false
  if customer and customer.tags contains 'provider-approved'
    assign provider_approved = true
  endif
%}

{% unless provider_approved %}
  <section class="ell-section">
    <div class="ell-container">
      {% render 'provider-access-gate',
        gate_eyebrow: 'Product Detail',
        gate_heading: 'Provider approval required to view product details',
        gate_body: 'Product specifications, pricing, ordering controls, and technical documentation are available to approved provider accounts.'
      %}
    </div>
  </section>
{% else %}
<script type="application/ld+json">
  {{ current_product | structured_data }}
</script>

<section class="ell-section">
  <div class="ell-container detail-layout">
    <div class="detail-main">
      <nav class="page-breadcrumbs" aria-label="Breadcrumb">
        <a href="{{ provider_registration_url }}">{{ section.settings.catalog_label }}</a>
        <span>/</span>
        <span>{{ product_title }}</span>
      </nav>

      <div>
        <div class="detail-kicker">
          <span class="status-chip {% if current_variant.available %}status-chip--verified{% else %}status-chip--limited{% endif %}">
            {% if current_variant.available %}
              {{ section.settings.status_label }}
            {% else %}
              {{ section.settings.unavailable_label }}
            {% endif %}
          </span>
          <span class="eyebrow" style="margin:0;">ID: {{ lot_id }}</span>
        </div>
        <h1 class="section-title">{{ product_title }}</h1>
        <p class="lead-copy detail-summary">{{ product_body }}</p>
      </div>

      <article class="coa-card">
        <div class="coa-card__head">
          <div>
            <h2 class="serif-title" style="margin:0;font-size:2.1rem;">{{ section.settings.coa_heading }}</h2>
            <p class="muted-copy" style="margin:0.35rem 0 0;">{{ coa_reference }}</p>
          </div>
          {% if coa_url != blank %}
            <a class="ell-button ell-button--text" href="{{ coa_url }}">
              {% render 'icon', name: 'download' %}
              {{ section.settings.coa_button }}
            </a>
          {% endif %}
        </div>

        <div class="detail-stats">
          {% assign metric_blocks = section.blocks | where: 'type', 'metric' %}
          {% if metric_blocks.size > 0 %}
            {% for block in metric_blocks %}
              {% if block.settings.label != blank and block.settings.value != blank %}
                <div class="metric-card" {{ block.shopify_attributes }}>
                  <span class="stat-label">{{ block.settings.label }}</span>
                  <div class="metric-card__value">{{ block.settings.value }}</div>
                </div>
              {% endif %}
            {% endfor %}
          {% else %}
            <div class="metric-card"><span class="stat-label">Viability</span><div class="metric-card__value">{{ viability }}</div></div>
            <div class="metric-card"><span class="stat-label">Passage</span><div class="metric-card__value">{{ passage }}</div></div>
            <div class="metric-card"><span class="stat-label">Sterility</span><div class="metric-card__value">{{ sterility }}</div></div>
            <div class="metric-card"><span class="stat-label">Endotoxin</span><div class="metric-card__value">{{ endotoxin }}</div></div>
          {% endif %}
        </div>

        <div class="coa-visual">
          {% if current_product.featured_image %}
            {{
              current_product.featured_image
              | image_url: width: 1200
              | image_tag:
                alt: product_title,
                widths: '600,900,1200',
                class: 'coa-visual__image',
                style: 'width:100%;height:100%;object-fit:cover;opacity:0.45;mix-blend-mode:multiply;'
            }}
          {% endif %}
          <span class="chip coa-visual__badge">{{ section.settings.scan_badge }}</span>
        </div>
      </article>

      <div>
        <h2 class="serif-title" style="margin:0 0 1.5rem;font-size:2rem;">{{ section.settings.spec_heading }}</h2>
        <div class="spec-grid">
          {% assign spec_blocks = section.blocks | where: 'type', 'spec' %}
          {% if spec_blocks.size > 0 %}
            {% for block in spec_blocks %}
              {% if block.settings.label != blank and block.settings.value != blank %}
                <div class="spec-item" {{ block.shopify_attributes }}>
                  <span class="stat-label">{{ block.settings.label }}</span>
                  <strong>{{ block.settings.value }}</strong>
                </div>
              {% endif %}
            {% endfor %}
          {% else %}
            <div class="spec-item"><span class="stat-label">Cell Type</span><strong>{{ cell_type }}</strong></div>
            <div class="spec-item"><span class="stat-label">Characterization</span><strong>{{ characterization }}</strong></div>
            <div class="spec-item"><span class="stat-label">Format</span><strong>{{ product_format }}</strong></div>
            <div class="spec-item"><span class="stat-label">Storage</span><strong>{{ storage }}</strong></div>
            <div class="spec-item"><span class="stat-label">SKU / Lot</span><strong>{{ lot_id }}</strong></div>
            <div class="spec-item"><span class="stat-label">Availability</span><strong>{% if current_variant.available %}Available{% else %}Unavailable{% endif %}</strong></div>
          {% endif %}
        </div>
      </div>
    </div>

    <aside class="detail-panel">
      <div class="catalog-alloc-panel__head">
        <div>
          <p class="eyebrow" style="margin-bottom:0.5rem;">{{ section.settings.panel_eyebrow }}</p>
          <h2 class="serif-title" style="margin:0;font-size:2.6rem;">{{ section.settings.panel_heading }}</h2>
        </div>
        <span class="status-chip status-chip--limited">{{ section.settings.panel_status }}</span>
      </div>

      <div class="product-procurement-price">
        <span class="stat-label">{{ section.settings.price_label }}</span>
        <strong>{{ current_variant.price | money }}</strong>
      </div>

      <div class="detail-panel__summary">
        <div class="detail-panel__line"><span class="muted-copy">Lead Time</span><strong>{{ lead_time }}</strong></div>
        <div class="detail-panel__line"><span class="muted-copy">Shipping Condition</span><strong>{{ shipping_condition }}</strong></div>
        <div class="detail-panel__line"><span class="muted-copy">Min. Order</span><strong>{{ minimum_order }}</strong></div>
      </div>

      {% form 'product', current_product, class: 'product-procurement-form' %}
        {% if current_product.has_only_default_variant %}
          <input type="hidden" name="id" value="{{ current_variant.id }}">
        {% else %}
          <label class="stat-label" for="product-variant-{{ section.id }}">{{ section.settings.variant_label }}</label>
          <select id="product-variant-{{ section.id }}" class="field-select" name="id">
            {% for variant in current_product.variants %}
              <option
                value="{{ variant.id }}"
                {% if variant.id == current_variant.id %}selected{% endif %}
                {% unless variant.available %}disabled{% endunless %}
              >
                {{ variant.title }} - {% if variant.available %}{{ variant.price | money }}{% else %}{{ section.settings.unavailable_label }}{% endif %}
              </option>
            {% endfor %}
          </select>
        {% endif %}

        <label class="stat-label" for="product-quantity-{{ section.id }}">{{ section.settings.quantity_label }}</label>
        <input
          id="product-quantity-{{ section.id }}"
          class="field"
          type="number"
          name="quantity"
          min="{{ selected_quantity }}"
          value="{{ selected_quantity }}"
        >
        <input type="hidden" name="properties[Lot ID]" value="{{ lot_id }}">
        <input type="hidden" name="properties[Cart pathway]" value="Provider and institution review requested">

        <button
          class="ell-button ell-button--primary product-procurement-form__submit"
          type="submit"
          name="add"
          {% unless current_variant.available %}disabled{% endunless %}
        >
          {{ section.settings.panel_button }}
          {% render 'icon', name: 'arrow-right' %}
        </button>
      {% endform %}

      <a class="ell-button ell-button--ghost product-procurement-form__cart" href="{{ cart_url }}">
        {{ section.settings.cart_label }}
      </a>

      <div class="verification-box">
        <div style="display:flex;gap:0.75rem;align-items:flex-start;">
          {% render 'icon', name: 'verified' %}
          <div>
            <strong>Provider account required</strong>
            <p class="muted-copy" style="margin:0.35rem 0 0;font-size:0.86rem;">Product visibility, pricing, documentation, and fulfillment details are reviewed through provider account setup.</p>
          </div>
        </div>
      </div>

      <div style="padding-top:1.5rem;">
        <p class="stat-label" style="margin-bottom:0.6rem;">{{ section.settings.badges_heading }}</p>
        <div style="display:flex;flex-wrap:wrap;gap:0.6rem;">
          {% assign badge_blocks = section.blocks | where: 'type', 'badge' %}
          {% if badge_blocks.size > 0 %}
            {% for block in badge_blocks %}
              {% if block.settings.label != blank %}
                <span class="status-chip status-chip--allocated" {{ block.shopify_attributes }}>{{ block.settings.label }}</span>
              {% endif %}
            {% endfor %}
          {% else %}
            <span class="status-chip status-chip--allocated">Documentation</span>
            <span class="status-chip status-chip--allocated">Quality Review</span>
            <span class="status-chip status-chip--allocated">Handling Specs</span>
          {% endif %}
        </div>
      </div>

      <div class="support-card surface-card">
        <span class="support-card__icon">{% render 'icon', name: 'support' %}</span>
        <div>
          <strong>{{ section.settings.support_heading }}</strong>
          <p class="muted-copy" style="margin:0.25rem 0 0;font-size:0.86rem;">{{ section.settings.support_body }}</p>
        </div>
      </div>
    </aside>
  </div>
</section>
{% endunless %}

{% schema %}
{
  "name": "ELL product detail",
  "max_blocks": 12,
  "blocks": [
    {
      "type": "metric",
      "name": "Metric",
      "settings": [
        { "type": "text", "id": "label", "label": "Label", "default": "Viability" },
        { "type": "text", "id": "value", "label": "Value", "default": "94.2%" }
      ]
    },
    {
      "type": "spec",
      "name": "Specification",
      "settings": [
        { "type": "text", "id": "label", "label": "Label", "default": "Cell Type" },
        { "type": "text", "id": "value", "label": "Value", "default": "Multipotent MSCs" }
      ]
    },
    {
      "type": "badge",
      "name": "Compliance badge",
      "settings": [
        { "type": "text", "id": "label", "label": "Label", "default": "Documentation" }
      ]
    }
  ],
  "settings": [
    { "type": "text", "id": "fallback_title", "label": "Fallback title", "default": "Mesenchymal Stem Cell Lineage" },
    { "type": "textarea", "id": "fallback_body", "label": "Fallback description", "default": "Quality-focused biologic solution prepared for provider-led documentation review and institutional ordering workflows." },
    { "type": "text", "id": "lot_id", "label": "Fallback lot ID", "default": "Available upon review" },
    { "type": "text", "id": "catalog_label", "label": "Catalog label", "default": "Catalog" },
    { "type": "text", "id": "status_label", "label": "Status label", "default": "Active Lot" },
    { "type": "text", "id": "unavailable_label", "label": "Unavailable label", "default": "Unavailable" },
    { "type": "text", "id": "coa_heading", "label": "COA heading", "default": "Certificate of Analysis" },
    { "type": "text", "id": "coa_reference", "label": "COA reference", "default": "Available upon provider or institutional review." },
    { "type": "text", "id": "coa_button", "label": "COA button label", "default": "Download PDF" },
    { "type": "url", "id": "coa_link", "label": "COA link" },
    { "type": "text", "id": "scan_badge", "label": "Scan badge", "default": "Documentation review" },
    { "type": "text", "id": "fallback_viability", "label": "Fallback viability", "default": "Available on request" },
    { "type": "text", "id": "fallback_passage", "label": "Fallback passage", "default": "Available on request" },
    { "type": "text", "id": "fallback_sterility", "label": "Fallback sterility", "default": "Available on request" },
    { "type": "text", "id": "fallback_endotoxin", "label": "Fallback endotoxin", "default": "Available on request" },
    { "type": "text", "id": "fallback_cell_type", "label": "Fallback cell type", "default": "Biologic solution" },
    { "type": "text", "id": "fallback_characterization", "label": "Fallback characterization", "default": "Pending review" },
    { "type": "text", "id": "fallback_format", "label": "Fallback format", "default": "Single lot" },
    { "type": "text", "id": "fallback_storage", "label": "Fallback storage", "default": "Controlled cold-chain" },
    { "type": "text", "id": "spec_heading", "label": "Specifications heading", "default": "Technical Specifications" },
    { "type": "text", "id": "panel_eyebrow", "label": "Panel eyebrow", "default": "Cart" },
    { "type": "text", "id": "panel_heading", "label": "Panel heading", "default": "Request Allocation" },
    { "type": "text", "id": "panel_status", "label": "Panel status", "default": "Provider Review" },
    { "type": "text", "id": "price_label", "label": "Price label", "default": "Allocation Price" },
    { "type": "text", "id": "lead_time", "label": "Lead time", "default": "48-72 Hours" },
    { "type": "text", "id": "shipping_condition", "label": "Shipping condition", "default": "Subject to product specifications" },
    { "type": "text", "id": "minimum_order", "label": "Minimum order", "default": "1 Unit" },
    { "type": "text", "id": "variant_label", "label": "Variant label", "default": "Lot / Variant" },
    { "type": "text", "id": "quantity_label", "label": "Quantity label", "default": "Quantity" },
    { "type": "text", "id": "panel_button", "label": "Panel button label", "default": "Add to Cart" },
    { "type": "text", "id": "cart_label", "label": "Cart label", "default": "Review Cart" },
    { "type": "text", "id": "badges_heading", "label": "Compliance heading", "default": "Review Materials" },
    { "type": "text", "id": "support_heading", "label": "Support heading", "default": "Speak with a Bio-Specialist" },
    { "type": "text", "id": "support_body", "label": "Support body", "default": "Support for documentation, ordering, and handling questions." }
  ]
}
{% endschema %}
