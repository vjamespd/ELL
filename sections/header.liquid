      "type": "text",
      "id": "home_label",
      "label": "Home label",
      "default": "Home"
    },
    {
      "type": "text",
      "id": "catalog_label",
      "label": "Catalog label",
      "default": "Catalog"
    },
    {
      "type": "text",
      "id": "quality_label",
      "label": "Quality label",
      "default": "Quality & Safety"
    },
    {
      "type": "url",
      "id": "quality_link",
      "label": "Quality link"
    },
    {
      "type": "text",
      "id": "about_label",
      "label": "About label",
      "default": "About Us"
    },
    {
      "type": "url",
      "id": "about_link",
      "label": "About link"
    },
    {
      "type": "text",
      "id": "provider_label",
      "label": "Provider label",
      "default": "Provider"
    },
    {
      "type": "text",
      "id": "provider_info_label",
      "label": "Provider info label",
      "default": "Provider Info"
    },
    {
      "type": "url",
      "id": "provider_info_link",
      "label": "Provider info link"
    },
    {
      "type": "text",
      "id": "provider_account_label",
      "label": "Provider account setup label",
      "default": "Provider Account Setup"
    },
    {
      "type": "url",
      "id": "provider_account_link",
      "label": "Provider account setup link"
    },
    {
      "type": "text",
      "id": "provider_order_label",
      "label": "Pricing/order form label",
      "default": "Pricing/Order Form"
    },
    {
      "type": "url",
      "id": "provider_order_link",
      "label": "Pricing/order form link"
    },
    {
      "type": "text",
      "id": "cart_label",
      "label": "Cart label",
      "default": "Cart"
    },
    {
      "type": "text",
      "id": "login_label",
      "label": "Login label",
      "default": "Log In"
    }
  ]
}
{% endschema %}
