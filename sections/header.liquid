{% liquid
  assign brand_name = settings.brand_name | default: shop.name
  assign catalog_url = routes.all_products_collection_url | default: '/collections/all'
  assign cart_url = routes.cart_url | default: '/cart'
  assign quality_route = catalog_url | append: '?view=quality-safety'
  assign quality_url = section.settings.quality_link | default: quality_route
  assign about_route = catalog_url | append: '?view=about-us'
  assign about_url = section.settings.about_link | default: about_route
  assign home_active = false
  assign catalog_active = false
  assign quality_active = false
  assign about_active = false
  assign procurement_active = false
  assign contact_active = false
  assign provider_active = false
  assign cart_active = false
  assign quality_view_active = false
  assign featured_biologic_view_active = false
  assign provider_registration_view_active = false
  assign provider_registration_route_active = false
  assign provider_registration_url = catalog_url | append: '?view=provider-registration'
  assign gated_catalog_url = provider_registration_url
  assign provider_approved = false

  if customer and customer.tags contains 'provider-approved'
    assign provider_approved = true
    assign gated_catalog_url = catalog_url
  endif

  if request.params.view == 'quality-safety'
    assign quality_view_active = true
  endif

  if request.params.view == 'about-us'
    assign about_active = true
  endif

  if request.params.view == 'featured-biologic-of-the-month'
    assign featured_biologic_view_active = true
  endif

  if request.params.view == 'provider-registration'
    assign provider_registration_view_active = true
  endif

  if request.path contains 'provider-registration'
    assign provider_registration_route_active = true
  endif

  if template.name == 'index'
    assign home_active = true
  elsif template.suffix == 'about-us' or request.params.view == 'about-us'
    assign about_active = true
  elsif template.suffix == 'quality-safety' or request.path contains 'quality-safety' or quality_view_active
    assign quality_active = true
  elsif template.suffix == 'provider-registration' or provider_registration_view_active
    assign provider_active = true
  elsif template.suffix == 'featured-biologic-of-the-month' or featured_biologic_view_active
    assign home_active = true
  elsif request.path contains '/cart' or template.name == 'cart'
    assign cart_active = true
  elsif template.suffix == 'procurement' or request.path contains 'procurement'
    assign procurement_active = true
  elsif template.suffix == 'contact' or request.path contains 'contact'
    assign contact_active = true
  elsif request.path contains 'provider'
    assign provider_active = true
  elsif template.name == 'collection' or template.name == 'product' or template.suffix == 'catalog'
    assign catalog_active = true
  endif
%}

<header class="site-header">
  <div class="ell-container site-header__inner">
    <a class="brand-mark" href="{{ routes.root_url }}">
      <span class="brand-logo">
        <img class="brand-logo__image" src="{{ 'ell-logo-03.png' | asset_url }}" alt="ell. Elegance at the Cellular Level">
      </span>
    </a>

    <nav class="site-nav" aria-label="Primary">
      <a href="{{ routes.root_url }}" data-nav-key="home"{% if home_active %} aria-current="page"{% endif %}>{{ section.settings.home_label }}</a>
      <a href="{{ gated_catalog_url }}" data-nav-key="catalog"{% if catalog_active %} aria-current="page"{% endif %}>{{ section.settings.catalog_label }}</a>
      <a href="{{ quality_url }}" data-nav-key="quality"{% if quality_active %} aria-current="page"{% endif %}>{{ section.settings.quality_label }}</a>
      <a href="{{ provider_registration_url }}" data-nav-key="provider"{% if provider_active %} aria-current="page"{% endif %}>{{ section.settings.provider_label }}</a>
      <a href="{{ about_url }}" data-nav-key="about"{% if about_active %} aria-current="page"{% endif %}>{{ section.settings.about_label }}</a>
    </nav>

    <div class="site-header__actions">
      <a class="cart-action" href="{{ cart_url }}" aria-label="{{ section.settings.cart_label }}"{% if cart_active %} aria-current="page"{% endif %}>
        {% render 'icon', name: 'cart' %}
        <span class="cart-action__count">{{ cart.item_count }}</span>
      </a>
      <a class="ell-button ell-button--ghost" href="{{ routes.account_login_url | default: '/account/login' }}">
        {{ section.settings.login_label }}
      </a>
      <button class="nav-toggle" type="button" aria-label="Open menu" aria-controls="ell-mobile-nav" data-nav-toggle>
        {% render 'icon', name: 'menu' %}
      </button>
    </div>
  </div>

</header>

<div id="ell-mobile-nav" class="mobile-sheet" data-mobile-nav>
  <button class="mobile-sheet__backdrop" type="button" aria-label="Close menu" data-nav-backdrop></button>
  <div class="mobile-sheet__panel">
    <div style="display:flex;align-items:center;justify-content:space-between;gap:1rem;">
      <span class="brand-logo brand-logo--mobile">
        <img class="brand-logo__image" src="{{ 'ell-logo-03.png' | asset_url }}" alt="ell. Elegance at the Cellular Level">
      </span>
      <button class="mobile-sheet__close" type="button" aria-label="Close menu" data-nav-close>
        {% render 'icon', name: 'close' %}
      </button>
    </div>
    <nav class="mobile-sheet__menu" aria-label="Mobile">
      <a href="{{ routes.root_url }}" data-nav-key="home"{% if home_active %} aria-current="page"{% endif %}>{{ section.settings.home_label }}</a>
      <a href="{{ gated_catalog_url }}" data-nav-key="catalog"{% if catalog_active %} aria-current="page"{% endif %}>{{ section.settings.catalog_label }}</a>
      <a href="{{ quality_url }}" data-nav-key="quality"{% if quality_active %} aria-current="page"{% endif %}>{{ section.settings.quality_label }}</a>
      <a href="{{ provider_registration_url }}" data-nav-key="provider"{% if provider_active %} aria-current="page"{% endif %}>{{ section.settings.provider_label }}</a>
      <a href="{{ about_url }}" data-nav-key="about"{% if about_active %} aria-current="page"{% endif %}>{{ section.settings.about_label }}</a>
      <a href="/pages/contact"{% if contact_active %} aria-current="page"{% endif %}>Contact</a>
      <a href="{{ cart_url }}"{% if cart_active %} aria-current="page"{% endif %}>Cart</a>
      <a href="{{ routes.account_login_url | default: '/account/login' }}">{{ section.settings.login_label }}</a>
    </nav>
    <p class="muted-copy" style="margin-top:auto;">{{ settings.brand_tagline }}</p>
  </div>
</div>

<script>
  (() => {
    const applyHeaderActiveState = () => {
      const path = window.location.pathname.replace(/\/$/, '') || '/';
      const view = new URLSearchParams(window.location.search).get('view') || '';
      const activeKeys = new Set();

      const isAbout = view === 'about-us';
      const isQuality = view === 'quality-safety' || path.includes('quality-safety');
      const isProvider = view === 'provider-registration' || path.includes('provider-registration');
      const isFeaturedBiologic = view === 'featured-biologic-of-the-month';
      const isCatalog = !isProvider && !isQuality && !isFeaturedBiologic && !isAbout && (path.startsWith('/collections/') || path.startsWith('/products/'));

      if (path === '/' || isFeaturedBiologic) activeKeys.add('home');
      if (isCatalog) activeKeys.add('catalog');
      if (isQuality) activeKeys.add('quality');
      if (isAbout) activeKeys.add('about');
      if (isProvider) activeKeys.add('provider');

      document.querySelectorAll('[data-nav-key]').forEach((element) => {
        const key = element.getAttribute('data-nav-key');
        if (key && activeKeys.has(key)) {
          element.setAttribute('aria-current', 'page');
        } else {
          element.removeAttribute('aria-current');
        }
      });
    };

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', applyHeaderActiveState, { once: true });
    } else {
      applyHeaderActiveState();
    }
  })();
</script>

{% schema %}
{
  "name": "Header",
  "settings": [
    {
      "type": "text",
      "id": "home_label",
      "label": "Home label",
      "default": "Home"
    },
    {
      "type": "text",
      "id": "catalog_label",
      "label": "Catalog label",
      "default": "Product Catalog"
    },
    {
      "type": "text",
      "id": "quality_label",
      "label": "Quality label",
      "default": "Quality & Safety"
    },
    {
      "type": "url",
      "id": "quality_link",
      "label": "Quality link"
    },
    {
      "type": "text",
      "id": "about_label",
      "label": "About label",
      "default": "About Us"
    },
    {
      "type": "url",
      "id": "about_link",
      "label": "About link"
    },
    {
      "type": "text",
      "id": "provider_label",
      "label": "Provider label",
      "default": "Provider"
    },
    {
      "type": "text",
      "id": "cart_label",
      "label": "Cart label",
      "default": "Cart"
    },
    {
      "type": "text",
      "id": "login_label",
      "label": "Login label",
      "default": "Log In"
    }
  ]
}
{% endschema %}
