{% liquid
  assign featured_asset = 'matt-stang.jpeg'
%}

<section class="ell-section team-page">
  <div class="ell-container team-page__layout">
    <div class="team-page__intro">
      <p class="eyebrow">{{ section.settings.eyebrow }}</p>
      <h1 class="section-title">{{ page.title | default: section.settings.heading }}</h1>
      <p class="lead-copy">{{ section.settings.body }}</p>
    </div>

    <div class="team-grid">
      {% if section.blocks.size > 0 %}
        {% for block in section.blocks %}
          {% liquid
            assign profile_image = block.settings.image
            assign show_asset_fallback = false
            if profile_image == blank and forloop.first
              assign show_asset_fallback = true
            endif
          %}
          <article class="team-card surface-card" {{ block.shopify_attributes }}>
            <div class="team-card__media">
              {% if profile_image != blank %}
                {{
                  profile_image
                  | image_url: width: 1200
                  | image_tag:
                    alt: block.settings.name,
                    widths: '480,720,960,1200',
                    sizes: '(min-width: 1100px) 36vw, 100vw'
                }}
              {% elsif show_asset_fallback %}
                <img src="{{ featured_asset | asset_url }}" alt="{{ block.settings.name }}" loading="lazy">
              {% else %}
                <div class="team-card__placeholder" aria-hidden="true">{{ block.settings.initials | default: 'ell.' }}</div>
              {% endif %}
            </div>

            <div class="team-card__content">
              <div class="team-card__header">
                <div>
                  <p class="eyebrow">{{ block.settings.role }}</p>
                  <h2 class="serif-title">{{ block.settings.name }}</h2>
                </div>
                {% if block.settings.company != blank %}
                  <p class="team-card__company">{{ block.settings.company }}</p>
                {% endif %}
              </div>

              <div class="team-card__summary">
                {% if block.settings.bio_heading != blank %}
                  <p class="stat-label">{{ block.settings.bio_heading }}</p>
                {% endif %}
                <p class="team-card__bio">{{ block.settings.bio }}</p>
              </div>

              <div class="team-card__meta">
                {% if block.settings.phone != blank %}
                  <a class="team-card__meta-link" href="tel:{{ block.settings.phone | replace: '.', '' | replace: ' ', '' }}">
                    <span class="stat-label">Phone</span>
                    <strong>{{ block.settings.phone }}</strong>
                  </a>
                {% endif %}
                {% if block.settings.email != blank %}
                  <a class="team-card__meta-link" href="mailto:{{ block.settings.email }}">
                    <span class="stat-label">Email</span>
                    <strong>{{ block.settings.email }}</strong>
                  </a>
                {% endif %}
              </div>
            </div>
          </article>
        {% endfor %}
      {% else %}
        <article class="team-card surface-card">
          <div class="team-card__media">
            <img src="{{ featured_asset | asset_url }}" alt="Matt Stang" loading="lazy">
          </div>
          <div class="team-card__content">
            <div class="team-card__header">
              <div>
                <p class="eyebrow">Cofounder</p>
                <h2 class="serif-title">Matt Stang</h2>
              </div>
              <p class="team-card__company">Stangco</p>
            </div>

            <div class="team-card__summary">
              <p class="stat-label">Matt Stang Biography</p>
              <p class="team-card__bio">Matt Stang is a pioneer in the regulated health space leading and selling High Times before buying it back and cofounding a dozen companies in the regulated health space from peptides to psychedelics.</p>
            </div>

            <div class="team-card__meta">
              <a class="team-card__meta-link" href="tel:9179227937">
                <span class="stat-label">Phone</span>
                <strong>917.922.7937</strong>
              </a>
              <a class="team-card__meta-link" href="mailto:Matt@stangcollc.com">
                <span class="stat-label">Email</span>
                <strong>Matt@stangcollc.com</strong>
              </a>
            </div>
          </div>
        </article>
      {% endif %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "ELL team",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Leadership" },
    { "type": "text", "id": "heading", "label": "Fallback heading", "default": "Executive Team" },
    { "type": "textarea", "id": "body", "label": "Intro body", "default": "Meet the leadership team guiding ell. across provider relationships, strategic growth, and institutional workflows." }
  ],
  "blocks": [
    {
      "type": "member",
      "name": "Member",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Profile image" },
        { "type": "text", "id": "initials", "label": "Placeholder initials", "default": "MS" },
        { "type": "text", "id": "role", "label": "Role", "default": "Cofounder" },
        { "type": "text", "id": "name", "label": "Name", "default": "Matt Stang" },
        { "type": "text", "id": "company", "label": "Company", "default": "Stangco" },
        { "type": "text", "id": "bio_heading", "label": "Bio heading", "default": "Matt Stang Biography" },
        { "type": "textarea", "id": "bio", "label": "Biography", "default": "Matt Stang is a pioneer in the regulated health space leading and selling High Times before buying it back and cofounding a dozen companies in the regulated health space from peptides to psychedelics." },
        { "type": "text", "id": "phone", "label": "Phone", "default": "917.922.7937" },
        { "type": "text", "id": "email", "label": "Email", "default": "Matt@stangcollc.com" }
      ]
    }
  ],
  "presets": [
    {
      "name": "ELL team",
      "blocks": [
        {
          "type": "member"
        }
      ]
    }
  ]
}
{% endschema %}
