<section class="ell-section solutions-section">
  <div class="ell-container">
    <div class="solutions-editorial">
      <div class="solutions-editorial__intro">
        <p class="eyebrow">{{ section.settings.eyebrow }}</p>
        <h2 class="section-title solutions-editorial__title">{{ section.settings.heading }}</h2>
        <p class="lead-copy solutions-editorial__lead">{{ section.settings.intro }}</p>
      </div>

      <div class="solutions-editorial__stack">
        <article class="solutions-article surface-card">
          <div class="solutions-article__content">
            <p class="stat-label">{{ section.settings.block_1_eyebrow }}</p>
            <h3 class="serif-title solutions-article__title">{{ section.settings.block_1_title }}</h3>
            <p class="solutions-article__body">{{ section.settings.block_1_body }}</p>
          </div>
          <div class="solutions-article__visual solutions-article__visual--cells" aria-hidden="true">
            <img src="{{ 'ell-solutions-future-biologics.png' | asset_url }}" alt="" loading="lazy">
          </div>
        </article>

        <article class="solutions-article solutions-article--reverse surface-card">
          <div class="solutions-article__content">
            <p class="stat-label">{{ section.settings.block_2_eyebrow }}</p>
            <h3 class="serif-title solutions-article__title">{{ section.settings.block_2_title }}</h3>
            <p class="solutions-article__body">{{ section.settings.block_2_body }}</p>
          </div>
          <div class="solutions-article__visual solutions-article__visual--lab" aria-hidden="true">
            <img src="{{ 'ell-solutions-marketplace.png' | asset_url }}" alt="" loading="lazy">
          </div>
        </article>

        <article class="solutions-article surface-card">
          <div class="solutions-article__content">
            <p class="stat-label">{{ section.settings.block_3_eyebrow }}</p>
            <h3 class="serif-title solutions-article__title">{{ section.settings.block_3_title }}</h3>
            <p class="solutions-article__body">{{ section.settings.block_3_body }}</p>
          </div>
          <div class="solutions-article__visual solutions-article__visual--brand" aria-hidden="true">
            <img src="{{ 'ell-solutions-vision-v2.png' | asset_url }}" alt="" loading="lazy">
          </div>
        </article>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "ELL solutions",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "The Future of Biologics"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "The Future of Biologics Starts Here"
    },
    {
      "type": "textarea",
      "id": "intro",
      "label": "Intro",
      "default": "A clearer path for providers exploring biologics, regenerative medicine, and practice-ready clinical solutions."
    },
    {
      "type": "text",
      "id": "block_1_eyebrow",
      "label": "Block 1 eyebrow",
      "default": "Industry Direction"
    },
    {
      "type": "text",
      "id": "block_1_title",
      "label": "Block 1 title",
      "default": "Regenerative medicine is reshaping care."
    },
    {
      "type": "textarea",
      "id": "block_1_body",
      "label": "Block 1 body",
      "default": "Regenerative medicine is transforming healthcare by shifting the focus from simply managing disease to supporting the body's natural ability to repair, restore, and optimize function. Today, physicians are integrating biologic therapies—including stem cells, exosomes, platelet-rich plasma (PRP), growth factors, amniotic tissue products, regenerative injectables, advanced diagnostics, and complementary therapies—to create comprehensive treatment strategies across orthopedics, sports medicine, aesthetics, sexual wellness, wound care, pain management, longevity, and beyond. As innovation continues to accelerate, providers need more than access to products—they need a trusted resource that helps them confidently navigate an increasingly complex marketplace."
    },
    {
      "type": "text",
      "id": "block_2_eyebrow",
      "label": "Block 2 eyebrow",
      "default": "Why ELL"
    },
    {
      "type": "text",
      "id": "block_2_title",
      "label": "Block 2 title",
      "default": "One centralized marketplace for biologics."
    },
    {
      "type": "textarea",
      "id": "block_2_body",
      "label": "Block 2 body",
      "default": "ELL was built to solve that challenge. Rather than searching dozens of vendors, websites, conferences, and distributors, providers can access a single, centralized marketplace dedicated exclusively to biologics and regenerative medicine. From stem cell-related technologies and laboratory testing to premium supplements, procedural equipment, practice solutions, and emerging regenerative innovations, ELL brings together highly vetted products and services in one convenient platform. Every company represented is selected because of its commitment to quality, innovation, provider support, and advancing patient care, allowing physicians to spend less time sourcing products and more time focused on what matters most—their patients."
    },
    {
      "type": "text",
      "id": "block_3_eyebrow",
      "label": "Block 3 eyebrow",
      "default": "Vision"
    },
    {
      "type": "text",
      "id": "block_3_title",
      "label": "Block 3 title",
      "default": "More than a marketplace."
    },
    {
      "type": "textarea",
      "id": "block_3_body",
      "label": "Block 3 body",
      "default": "ELL is more than a marketplace—it is the destination for regenerative medicine. As the biologics industry continues to evolve, ELL is committed to leading the way by connecting providers with the products, technologies, and strategic resources that define the future of regenerative healthcare. Our vision is simple: build the most comprehensive biologics ecosystem available anywhere, where innovation meets integrity, trusted relationships drive better decisions, and medical providers have confidence that they are accessing some of the industry's most respected companies in one place. Whether you are building a new regenerative practice or expanding an established one, ELL is designed to be your trusted partner and the industry's leading source for biologic products, services, and solutions."
    }
  ]
}
{% endschema %}
