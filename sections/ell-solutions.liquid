<section class="ell-section solutions-section">
  <div class="ell-container">
    <div class="solutions-heading solutions-heading--narrative">
      <p class="eyebrow">{{ section.settings.eyebrow }}</p>
      <div class="solutions-story">
        <h2 class="section-title solutions-story__title"><em>{{ section.settings.heading }}</em></h2>
        <div class="solutions-story__layout">
          <p class="lead-copy solutions-story__body">{{ section.settings.body }}</p>
          <div class="solutions-story__content">
            <div class="solutions-story__panel surface-card">
              <p class="stat-label">{{ section.settings.panel_eyebrow }}</p>
              <p class="solutions-story__panel-copy">{{ section.settings.panel_body }}</p>
            </div>
            <div class="solutions-pill-grid">
              <span class="solutions-pill">{{ section.settings.pill_1 }}</span>
              <span class="solutions-pill">{{ section.settings.pill_2 }}</span>
              <span class="solutions-pill">{{ section.settings.pill_3 }}</span>
              <span class="solutions-pill">{{ section.settings.pill_4 }}</span>
              <span class="solutions-pill">{{ section.settings.pill_5 }}</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "ELL solutions",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Centralized Product Catalog"
    },
    {
      "type": "textarea",
      "id": "heading",
      "label": "Heading",
      "default": "ELL provides prescribing providers access to advanced biologic solutions, cellular banking services, IV supplies, supplements, and practice resources through one centralized Product Catalog."
    },
    {
      "type": "textarea",
      "id": "body",
      "label": "Body",
      "default": "Built to support modern regenerative and longevity practices with one streamlined destination for product discovery, provider review, and operational support."
    },
    {
      "type": "text",
      "id": "panel_eyebrow",
      "label": "Panel eyebrow",
      "default": "Platform Overview"
    },
    {
      "type": "textarea",
      "id": "panel_body",
      "label": "Panel body",
      "default": "One centralized destination for biologic access, review materials, operational support, and provider-facing practice resources."
    },
    {
      "type": "text",
      "id": "pill_1",
      "label": "Pill 1",
      "default": "Advanced biologic solutions"
    },
    {
      "type": "text",
      "id": "pill_2",
      "label": "Pill 2",
      "default": "Cellular banking services"
    },
    {
      "type": "text",
      "id": "pill_3",
      "label": "Pill 3",
      "default": "IV supplies"
    },
    {
      "type": "text",
      "id": "pill_4",
      "label": "Pill 4",
      "default": "Supplements"
    },
    {
      "type": "text",
      "id": "pill_5",
      "label": "Pill 5",
      "default": "Practice resources"
    }
  ]
}
{% endschema %}
