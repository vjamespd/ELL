{% liquid
  assign catalog_url = routes.all_products_collection_url | default: '/collections/all'
  assign provider_approved = false
  if customer and customer.tags contains 'provider-approved'
    assign provider_approved = true
  endif
%}

{% unless provider_approved %}
  <section class="ell-section">
    <div class="ell-container search-page">
      {% render 'provider-access-gate',
        gate_eyebrow: 'Search',
        gate_heading: 'Provider approval required to search product records',
        gate_body: 'Product search, technical records, pricing, and ordering paths are available after provider registration and internal approval.'
      %}
    </div>
  </section>
{% else %}
<section class="ell-section">
  <div class="ell-container search-page">
    <div class="search-page__hero">
      <p class="eyebrow">{{ section.settings.eyebrow }}</p>
      <h1 class="section-title">{{ section.settings.heading }}</h1>
      <form class="search-page__form" action="{{ routes.search_url }}" method="get" role="search">
        <div class="search-field">
          {% render 'icon', name: 'search' %}
          <input
            class="field"
            type="search"
            name="q"
            value="{{ search.terms | escape }}"
            aria-label="{{ section.settings.placeholder }}"
            placeholder="{{ section.settings.placeholder }}"
            autocomplete="off"
          >
        </div>
        <button class="ell-button ell-button--primary" type="submit">{{ section.settings.button_label }}</button>
      </form>
    </div>

    {% if search.performed %}
      <div class="search-page__summary">
        <span class="muted-copy">{{ search.results_count }} result{% if search.results_count != 1 %}s{% endif %} for "{{ search.terms | escape }}"</span>
        <a class="ell-button ell-button--text" href="{{ catalog_url }}">{{ section.settings.catalog_label }}</a>
      </div>

      {% paginate search.results by section.settings.results_per_page %}
        {% if search.results_count > 0 %}
          <div class="search-results-grid">
            {% for item in search.results %}
              {% if item.object_type == 'product' %}
                {% liquid
                  assign product = item
                  assign current_variant = product.selected_or_first_available_variant
                %}
                <article class="collection-product-card">
                  <a class="collection-product-card__media" href="{{ product.url }}">
                    {% if product.featured_image %}
                      {{
                        product.featured_image
                        | image_url: width: 720
                        | image_tag:
                          alt: product.title,
                          widths: '360,540,720',
                          sizes: '(min-width: 1100px) 30vw, 100vw'
                      }}
                    {% else %}
                      <span class="collection-product-card__placeholder">ell.</span>
                    {% endif %}
                  </a>
                  <div class="collection-product-card__body">
                    <div class="collection-product-card__head">
                      <div>
                        <p class="stat-label">{{ product.type | default: product.vendor }}</p>
                        <h2 class="solution-card__title"><a href="{{ product.url }}">{{ product.title }}</a></h2>
                      </div>
                      <span class="status-chip {% if product.available %}status-chip--in-stock{% else %}status-chip--limited{% endif %}">
                        {% if product.available %}{{ section.settings.available_label }}{% else %}{{ section.settings.sold_out_label }}{% endif %}
                      </span>
                    </div>
                    <p class="muted-copy">{{ product.description | strip_html | truncate: 140 }}</p>
                    <div class="collection-product-card__meta">
                      <div>
                        <span class="stat-label">{{ section.settings.price_label }}</span>
                        <strong>{{ current_variant.price | money }}</strong>
                      </div>
                      <a class="ell-button ell-button--ghost" href="{{ product.url }}">{{ section.settings.details_label }}</a>
                    </div>
                  </div>
                </article>
              {% else %}
                <a class="search-result-card" href="{{ item.url }}">
                  <span class="resource-card__icon">{% render 'icon', name: 'file' %}</span>
                  <div>
                    <span class="stat-label">{{ item.object_type }}</span>
                    <strong>{{ item.title }}</strong>
                    {% if item.content != blank %}
                      <p class="muted-copy">{{ item.content | strip_html | truncate: 140 }}</p>
                    {% endif %}
                  </div>
                </a>
              {% endif %}
            {% endfor %}
          </div>

          {% if paginate.pages > 1 %}
            <nav class="collection-pagination" aria-label="Search pagination">
              {% if paginate.previous %}
                <a class="ell-button ell-button--ghost" href="{{ paginate.previous.url }}">
                  {% render 'icon', name: 'arrow-left' %}
                  {{ section.settings.previous_label }}
                </a>
              {% endif %}
              <span class="muted-copy">{{ section.settings.page_label }} {{ paginate.current_page }} / {{ paginate.pages }}</span>
              {% if paginate.next %}
                <a class="ell-button ell-button--ghost" href="{{ paginate.next.url }}">
                  {{ section.settings.next_label }}
                  {% render 'icon', name: 'arrow-right' %}
                </a>
              {% endif %}
            </nav>
          {% endif %}
        {% else %}
          <div class="catalog-empty is-visible">
            <h2 class="serif-title">{{ section.settings.empty_heading }}</h2>
            <p class="muted-copy">{{ section.settings.empty_body }}</p>
            <a class="ell-button ell-button--primary" href="{{ catalog_url }}">{{ section.settings.catalog_label }}</a>
          </div>
        {% endif %}
      {% endpaginate %}
    {% endif %}
  </div>
</section>
{% endunless %}

{% schema %}
{
  "name": "ELL search",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Search" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Search the inventory" },
    { "type": "text", "id": "placeholder", "label": "Placeholder", "default": "Search products, lots, documentation..." },
    { "type": "text", "id": "button_label", "label": "Button label", "default": "Search" },
    { "type": "text", "id": "catalog_label", "label": "Catalog label", "default": "Browse Inventory" },
    { "type": "text", "id": "available_label", "label": "Available label", "default": "Available" },
    { "type": "text", "id": "sold_out_label", "label": "Sold out label", "default": "Unavailable" },
    { "type": "text", "id": "price_label", "label": "Price label", "default": "Price" },
    { "type": "text", "id": "details_label", "label": "Details label", "default": "View Details" },
    { "type": "text", "id": "empty_heading", "label": "Empty heading", "default": "No results found." },
    { "type": "textarea", "id": "empty_body", "label": "Empty body", "default": "Try a different product name, lot ID, or browse the full inventory." },
    { "type": "text", "id": "previous_label", "label": "Previous label", "default": "Previous" },
    { "type": "text", "id": "next_label", "label": "Next label", "default": "Next" },
    { "type": "text", "id": "page_label", "label": "Page label", "default": "Page" },
    { "type": "range", "id": "results_per_page", "label": "Results per page", "min": 4, "max": 24, "step": 4, "default": 12 }
  ]
}
{% endschema %}
