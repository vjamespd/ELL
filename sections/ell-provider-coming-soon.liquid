{% liquid
  assign catalog_url = routes.all_products_collection_url | default: '/collections/all'
  assign route_handle = request.params.view | default: section.settings.route_handle
  assign eyebrow = section.settings.eyebrow
  assign heading = section.settings.heading
  assign body = section.settings.body
  assign secondary_label = section.settings.secondary_label
  assign secondary_url = section.settings.secondary_url
  assign provider_registration_url = catalog_url | append: '?view=provider-registration'
  assign provider_approved = false

  if customer and customer.tags contains 'provider-approved'
    assign provider_approved = true
  endif

  case route_handle
    when 'provider-info'
      assign eyebrow = 'Provider Access'
      assign heading = 'Coming Soon'
      assign body = 'Provider information will be published here soon, including access expectations, review steps, and onboarding guidance for clinical accounts.'
    when 'pricing-order-form'
      assign eyebrow = 'Provider Access'
      assign heading = 'Coming Soon'
      assign body = 'Pricing and order-form materials will appear here once provider access is enabled and documentation workflows are finalized.'
  endcase

  if secondary_url == blank
    assign secondary_url = catalog_url
  endif
%}

{% unless provider_approved %}
  <section class="ell-section ell-error-page">
    <div class="ell-container">
      {% render 'provider-access-gate',
        gate_eyebrow: 'Provider Access',
        gate_heading: 'Provider approval required',
        gate_body: 'Provider resources are available after account setup and internal ELL review.'
      %}
    </div>
  </section>
{% else %}
<section class="ell-section ell-error-page">
  <div class="ell-container">
    <div class="error-shell surface-card">
      <p class="eyebrow">{{ eyebrow }}</p>
      <h1 class="display-title">{{ heading }}</h1>
      <p class="lead-copy">{{ body }}</p>

      <div class="button-row" style="margin-top: 2rem;">
        <a class="ell-button ell-button--primary" href="{{ routes.root_url }}">
          {{ section.settings.primary_label }}
          {% render 'icon', name: 'arrow-right' %}
        </a>
        <a class="ell-button ell-button--ghost" href="{{ secondary_url }}">
          {{ secondary_label }}
        </a>
      </div>
    </div>
  </div>
</section>
{% endunless %}

{% schema %}
{
  "name": "Provider Soon",
  "settings": [
    {
      "type": "text",
      "id": "route_handle",
      "label": "Route handle",
      "default": "provider-info"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Provider Access"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Coming Soon"
    },
    {
      "type": "textarea",
      "id": "body",
      "label": "Body",
      "default": "Provider access is coming soon."
    },
    {
      "type": "text",
      "id": "primary_label",
      "label": "Primary button label",
      "default": "Return Home"
    },
    {
      "type": "text",
      "id": "secondary_label",
      "label": "Secondary button label",
      "default": "Browse Inventory"
    },
    {
      "type": "url",
      "id": "secondary_url",
      "label": "Secondary button URL"
    }
  ]
}
{% endschema %}
